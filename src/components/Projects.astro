---
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
---
<section id="projects" class="py-20 md:py-28 border-b border-b-neutral-200/30 dark:border-b-neutral-800/30">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Title -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-16">
      <div>
        <span class="font-mono text-xs font-bold text-accent tracking-widest uppercase block mb-2">// 03. FEATURED WORK</span>
        <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-neutral-950 dark:text-neutral-50">
          Selected Projects
        </h2>
      </div>
      <p class="font-mono text-xs text-neutral-400 dark:text-neutral-500 hidden md:block select-none">
        0xAB // PORTFOLIO_CASE_STUDIES
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8">
      {projects.map((project) => (
        <div class="group border border-neutral-200 dark:border-neutral-800 hover:border-accent dark:hover:border-accent bg-white dark:bg-neutral-900/40 rounded-2xl p-6 sm:p-8 flex flex-col justify-between transition-all duration-300 relative overflow-hidden shadow-sm hover:shadow-md">
          <!-- Accent Glow on Hover -->
          <div class="absolute top-0 right-0 w-24 h-24 bg-accent/5 rounded-bl-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>

          <div>
            <!-- Title & External Link -->
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg sm:text-xl font-bold text-neutral-950 dark:text-neutral-50 group-hover:text-accent dark:group-hover:text-accent transition-colors">
                {project.data.title}
              </h3>
              <div class="flex items-center gap-3 text-neutral-500 hover:text-neutral-800 dark:hover:text-neutral-200 transition-colors">
                {project.data.githubUrl && (
                  <a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer" aria-label="GitHub Repository" class="cursor-pointer">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                    </svg>
                  </a>
                )}
                {project.data.demoUrl && project.data.demoUrl !== "#" && project.data.demoUrl !== "" && (
                  <a href={project.data.demoUrl} aria-label="Live Demo" class="cursor-pointer">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"></path>
                    </svg>
                  </a>
                )}
              </div>
            </div>

            <!-- Description -->
            <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-6 leading-relaxed">
              {project.data.description}
            </p>
          </div>

          <!-- Meta / Tags -->
          <div class="flex flex-wrap gap-2 font-mono text-[10px] text-neutral-500">
            {project.data.tags.map((tag) => (
              <span class="px-2 py-0.5 border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/60 rounded">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
