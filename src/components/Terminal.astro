---
import { getCollection } from 'astro:content';

const allProfiles = await getCollection('profile');
const profileEntry = allProfiles[0];
const profile = profileEntry?.data;

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => a.data.order - b.data.order);

const profileData = {
  name: profile?.name || "Agung Bahtiar",
  role: profile?.role || "Software Engineer",
  subRole: profile?.subRole || "System Admin",
  email: profile?.email || "contact@0xab.tech",
  github: profile?.github || "https://github.com/0xab",
  linkedin: profile?.linkedin || "#",
  location: profile?.location || "Indonesia // GMT+7",
  skills: "Go, TypeScript, JavaScript, Python, Node.js, Linux (Ubuntu/Debian), Bash, Docker, Nginx, PostgreSQL, Redis"
};

const projectsData = sortedProjects.map((p) => ({
  title: p.data.title,
  description: p.data.description,
  githubUrl: p.data.githubUrl || "",
  tags: p.data.tags
}));
---
<section id="terminal" class="py-20 md:py-28 border-b border-neutral-200/30 dark:border-neutral-800/30 bg-neutral-900 text-neutral-100 font-mono">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    
    <!-- Title Info -->
    <div class="mb-8 text-center sm:text-left">
      <span class="text-xs font-bold text-accent tracking-widest uppercase block mb-2">// INTERACTIVE ENVIRONMENT</span>
      <h2 class="text-2xl sm:text-3xl font-black tracking-tight text-white font-sans">
        0xAb Command Line Interface
      </h2>
      <p class="text-xs text-neutral-400 mt-2 font-sans">
        Click inside the terminal block below and run commands directly to query this server.
      </p>
    </div>

    <!-- Terminal Window -->
    <div 
      id="terminal-window" 
      class="border border-neutral-800 bg-neutral-950 rounded-xl overflow-hidden shadow-2xl relative text-xs sm:text-sm select-text"
      role="region"
      aria-label="Interactive Terminal Console"
    >
      <!-- Top Control Bar -->
      <div class="bg-neutral-900 px-4 py-3 flex items-center justify-between border-b border-neutral-800 select-none">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
        </div>
        <span class="text-[10px] text-neutral-500 font-bold tracking-wider">tty1 // guest@0xAb.sh</span>
        <span class="text-[10px] text-neutral-500">Ctrl+L to Clear</span>
      </div>

      <!-- Scrollable Terminal Body -->
      <div id="terminal-body" class="p-6 h-[400px] overflow-y-auto space-y-3 scrollbar-thin">
        <!-- Initial Message -->
        <div class="text-neutral-400">
          <p class="text-accent font-bold">0xAb Interactive OS v1.0.4 (Astro-powered)</p>
          <p class="text-neutral-500">System initialization... [ OK ]</p>
          <p class="text-neutral-500">Type <span class="text-accent font-bold">help</span> to view all available commands.</p>
          <p class="text-neutral-500">--------------------------------------------------</p>
        </div>

        <!-- History/Output Wrapper -->
        <div id="terminal-history" class="space-y-3"></div>

        <!-- Current Command Input Line -->
        <div class="flex items-center gap-2" id="input-line">
          <span class="text-accent flex-shrink-0">guest@0xAb:~$</span>
          <input 
            type="text" 
            id="terminal-input" 
            class="bg-transparent border-none outline-none text-neutral-100 flex-grow caret-accent font-mono p-0 select-text"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            aria-label="Terminal input"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ profileData, projectsData }}>
  function setupTerminal() {
    const terminalWindow = document.getElementById('terminal-window');
    const terminalBody = document.getElementById('terminal-body');
    const terminalHistory = document.getElementById('terminal-history');
    const terminalInput = document.getElementById('terminal-input');

    if (!terminalWindow || !terminalBody || !terminalHistory || !terminalInput) return;

    // Focus input on terminal click
    terminalWindow.addEventListener('click', () => {
      const selection = window.getSelection();
      if (selection && selection.toString().length === 0) {
        terminalInput.focus();
      }
    });

    const commandHistory = [];
    let historyIndex = -1;

    // Custom neofetch art and info
    const neofetchOutput = `
<div class="flex flex-col sm:flex-row gap-6 items-start font-mono leading-relaxed">
  <pre class="text-accent font-bold text-center sm:text-left select-none">
  .▄▄▄▄   ▄▄▄ ▄▄▄▄· 
  ██▪ ██ █  █ ██▪ ██ 
  ██▪ ██  ▀▀  ██▪ ██ 
  ▒██.██ █  █ ▒██.██ 
   ▀▀▀▀   ▀▀▀  ▀▀▀▀  
  </pre>
  <div class="space-y-1">
    <p class="font-bold text-neutral-100">guest@0xAb</p>
    <p class="text-neutral-500">-------------</p>
    <p><span class="text-accent">OS:</span> Astro Linux x86_64</p>
    <p><span class="text-accent">Host:</span> ${profileData.name} Portfolio (0xAb.tech)</p>
    <p><span class="text-accent">Kernel:</span> 7.0.6-astro-release</p>
    <p><span class="text-accent">Uptime:</span> 99.99% stable</p>
    <p><span class="text-accent">Shell:</span> bash 5.2-interactive</p>
    <p><span class="text-accent">Theme:</span> Mono-Dark (with #FFD93D accents)</p>
    <p><span class="text-accent">CPU:</span> ${profileData.role} & ${profileData.subRole}</p>
    <p><span class="text-accent">Memory:</span> 16GB / 100% Passion</p>
    <div class="flex gap-1.5 mt-2">
      <span class="w-4 h-4 bg-neutral-900 border border-neutral-700"></span>
      <span class="w-4 h-4 bg-red-600"></span>
      <span class="w-4 h-4 bg-green-600"></span>
      <span class="w-4 h-4 bg-accent"></span>
      <span class="w-4 h-4 bg-blue-600"></span>
      <span class="w-4 h-4 bg-purple-600"></span>
      <span class="w-4 h-4 bg-white"></span>
    </div>
  </div>
</div>`;

    const helpOutput = `
<div class="space-y-1">
  <p class="font-bold text-neutral-200">Available commands:</p>
  <p>  <span class="text-accent font-bold">about</span>       - Brief overview of who I am</p>
  <p>  <span class="text-accent font-bold">skills</span>      - My technical skill sets</p>
  <p>  <span class="text-accent font-bold">projects</span>    - Showcase of main software and systems work</p>
  <p>  <span class="text-accent font-bold">neofetch</span>    - Print server neofetch diagnostic profile</p>
  <p>  <span class="text-accent font-bold">contact</span>     - How to get in touch with me</p>
  <p>  <span class="text-accent font-bold">email</span>       - Display primary contact email</p>
  <p>  <span class="text-accent font-bold">clear</span>       - Clear the screen buffer</p>
</div>`;

    const aboutOutput = `
<div class="space-y-2 max-w-xl">
  <p class="font-bold text-neutral-200">${profileData.name} [${profileData.role} & ${profileData.subRole}]</p>
  <p>I build performant backend systems and design reliable, automated server environments.</p>
  <p>Currently specializing in Go, Node.js, Linux systems, Nginx/reverse proxies, and container orchestration.</p>
</div>`;

    const skillsOutput = `
<div class="space-y-2">
  <p class="font-bold text-neutral-200">Technical Competencies:</p>
  <p>• <span class="text-accent">Core Skills:</span> ${profileData.skills}</p>
</div>`;

    const projectsOutput = `
<div class="space-y-3">
  <p class="font-bold text-neutral-200">Selected Work Highlights:</p>
  ${projectsData.map((project, index) => `
  <div>
    <p class="text-accent font-bold">${index + 1}. ${project.title} [${project.tags.join(', ')}]</p>
    <p class="pl-4 text-neutral-400">${project.description}</p>
    ${project.githubUrl ? `<p class="pl-4 text-[10px] text-neutral-500">Source: <a href="${project.githubUrl}" target="_blank" class="underline hover:text-white">${project.githubUrl}</a></p>` : ''}
  </div>
  `).join('')}
</div>`;

    const contactOutput = `
<div class="space-y-1">
  <p class="font-bold text-neutral-200">Connect with me:</p>
  <p>• GitHub:   <a href="${profileData.github}" target="_blank" class="text-accent underline hover:text-white transition-colors">${profileData.github.replace('https://', '')}</a></p>
  <p>• Email:    <a href="mailto:${profileData.email}" class="text-accent underline hover:text-white transition-colors">${profileData.email}</a></p>
  <p>• LinkedIn: <a href="${profileData.linkedin}" target="_blank" class="text-accent underline hover:text-white transition-colors">${profileData.linkedin.replace('https://', '')}</a></p>
</div>`;

    const emailOutput = `
<p>Primary contact: <a href="mailto:${profileData.email}" class="text-accent underline">${profileData.email}</a></p>
`;

    // Process commands
    function processCommand(rawInput) {
      const input = rawInput.trim().toLowerCase();
      
      if (input.length > 0 && (commandHistory.length === 0 || commandHistory[commandHistory.length - 1] !== rawInput)) {
        commandHistory.push(rawInput);
      }
      historyIndex = commandHistory.length;

      const commandLine = document.createElement('div');
      commandLine.className = 'flex items-center gap-2 font-bold';
      commandLine.innerHTML = `<span class="text-accent">guest@0xAb:~$</span> <span class="text-neutral-100">${rawInput}</span>`;
      terminalHistory.appendChild(commandLine);

      const responseLine = document.createElement('div');
      responseLine.className = 'text-neutral-300 pl-4 border-l border-neutral-800/80 py-1';

      if (input === '') {
        return;
      }

      switch (input) {
        case 'help':
          responseLine.innerHTML = helpOutput;
          break;
        case 'about':
          responseLine.innerHTML = aboutOutput;
          break;
        case 'skills':
          responseLine.innerHTML = skillsOutput;
          break;
        case 'projects':
          responseLine.innerHTML = projectsOutput;
          break;
        case 'neofetch':
          responseLine.innerHTML = neofetchOutput;
          break;
        case 'contact':
          responseLine.innerHTML = contactOutput;
          break;
        case 'email':
          responseLine.innerHTML = emailOutput;
          break;
        case 'clear':
          terminalHistory.innerHTML = '';
          return;
        default:
          responseLine.innerHTML = `<p class="text-red-400">Command not found: '${rawInput}'. Type <span class="text-accent font-bold">help</span> to view list of commands.</p>`;
          break;
      }

      terminalHistory.appendChild(responseLine);
      
      setTimeout(() => {
        terminalBody.scrollTop = terminalBody.scrollHeight;
      }, 50);
    }

    terminalInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const val = terminalInput.value;
        terminalInput.value = '';
        processCommand(val);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (historyIndex > 0) {
          historyIndex--;
          terminalInput.value = commandHistory[historyIndex];
        }
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (historyIndex < commandHistory.length - 1) {
          historyIndex++;
          terminalInput.value = commandHistory[historyIndex];
        } else {
          historyIndex = commandHistory.length;
          terminalInput.value = '';
        }
      } else if (e.key === 'l' && e.ctrlKey) {
        e.preventDefault();
        processCommand('clear');
      }
    });
  }

  setupTerminal();
  document.addEventListener('astro:after-swap', setupTerminal);
</script>
