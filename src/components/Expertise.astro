---
---
<section id="expertise" class="py-20 md:py-28 border-b border-neutral-200/30 dark:border-neutral-800/30 bg-neutral-100/30 dark:bg-neutral-900/10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Title -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-16">
      <div>
        <span class="font-mono text-xs font-bold text-accent tracking-widest uppercase block mb-2">// 02. EXPERTISE</span>
        <h2 class="text-3xl sm:text-4xl font-black tracking-tight text-neutral-950 dark:text-neutral-50">
          Core Capabilities
        </h2>
      </div>
      <p class="font-mono text-xs text-neutral-400 dark:text-neutral-500 hidden md:block select-none">
        0xAB // DUAL_SPECIALIZATION
      </p>
    </div>

    <!-- Dual Profile Panels -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      
      <!-- Panel 1: Software Engineering (Code view) -->
      <div class="border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/40 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
        <!-- Tab Bar -->
        <div class="bg-neutral-100/80 dark:bg-neutral-900/60 px-4 py-3 border-b border-neutral-200 dark:border-neutral-800 flex items-center justify-between font-mono text-[11px] text-neutral-500">
          <div class="flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-neutral-300 dark:bg-neutral-700"></span>
            <span>developer.ts</span>
          </div>
          <span>TypeScript // UTF-8</span>
        </div>
        
        <!-- Code Content -->
        <div class="p-6 sm:p-8 font-mono text-xs sm:text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed overflow-x-auto">
          <div class="text-blue-500 dark:text-blue-400">const <span class="text-neutral-800 dark:text-neutral-200">SoftwareEngineer</span> = &#123;</div>
          
          <div class="pl-4 sm:pl-6 my-2">
            <div class="text-neutral-500">// Languages I write fluently</div>
            <div>
              <span class="text-purple-500 dark:text-purple-400">languages</span>: [
              <span class="text-amber-600 dark:text-accent">"Go"</span>, 
              <span class="text-amber-600 dark:text-accent">"TypeScript"</span>, 
              <span class="text-amber-600 dark:text-accent">"JavaScript"</span>, 
              <span class="text-amber-600 dark:text-accent">"Python"</span>
              ],
            </div>

            <div class="text-neutral-500 mt-3">// Frameworks & environments</div>
            <div>
              <span class="text-purple-500 dark:text-purple-400">frameworks</span>: [
              <span class="text-amber-600 dark:text-accent">"Node.js"</span>, 
              <span class="text-amber-600 dark:text-accent">"Astro"</span>, 
              <span class="text-amber-600 dark:text-accent">"Express"</span>, 
              <span class="text-amber-600 dark:text-accent">"Fastify"</span>
              ],
            </div>

            <div class="text-neutral-500 mt-3">// Data layers</div>
            <div>
              <span class="text-purple-500 dark:text-purple-400">databases</span>: [
              <span class="text-amber-600 dark:text-accent">"PostgreSQL"</span>, 
              <span class="text-amber-600 dark:text-accent">"Redis"</span>, 
              <span class="text-amber-600 dark:text-accent">"MongoDB"</span>, 
              <span class="text-amber-600 dark:text-accent">"SQLite"</span>
              ],
            </div>

            <div class="text-neutral-500 mt-3">// API architectural patterns</div>
            <div>
              <span class="text-purple-500 dark:text-purple-400">apiDesign</span>: [
              <span class="text-amber-600 dark:text-accent">"RESTful APIs"</span>, 
              <span class="text-amber-600 dark:text-accent">"gRPC"</span>, 
              <span class="text-amber-600 dark:text-accent">"WebSockets"</span>
              ]
            </div>
          </div>
          
          <div class="text-blue-500 dark:text-blue-400">&#125;;</div>
        </div>
      </div>

      <!-- Panel 2: System Administration (Config view) -->
      <div class="border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900/40 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
        <!-- Tab Bar -->
        <div class="bg-neutral-100/80 dark:bg-neutral-900/60 px-4 py-3 border-b border-neutral-200 dark:border-neutral-800 flex items-center justify-between font-mono text-[11px] text-neutral-500">
          <div class="flex items-center gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-neutral-300 dark:bg-neutral-700"></span>
            <span>sysadmin.service</span>
          </div>
          <span>Systemd // INI</span>
        </div>
        
        <!-- Config Content -->
        <div class="p-6 sm:p-8 font-mono text-xs sm:text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed overflow-x-auto">
          <div class="text-neutral-800 dark:text-neutral-200 font-bold">[Unit]</div>
          <div class="text-neutral-500">// Core server skills & platforms</div>
          <div>Description=Agung Bahtiar - SysAdmin Operations</div>
          <div>After=network.target</div>
          
          <div class="text-neutral-800 dark:text-neutral-200 font-bold mt-4">[Service]</div>
          <div class="text-neutral-500">// Infrastructure & Orchestration</div>
          <div>ExecStart=/usr/bin/infra-ops \<br/>
            &nbsp;&nbsp;--os=<span class="text-amber-600 dark:text-accent">"Linux (Ubuntu, Debian, RHEL)"</span> \<br/>
            &nbsp;&nbsp;--containers=<span class="text-amber-600 dark:text-accent">"Docker & Compose"</span> \<br/>
            &nbsp;&nbsp;--orchestration=<span class="text-amber-600 dark:text-accent">"Kubernetes (K3s)"</span> \<br/>
            &nbsp;&nbsp;--automation=<span class="text-amber-600 dark:text-accent">"Bash Scripting & Cron"</span></div>
          
          <div class="text-neutral-500 mt-3">// Networking & Security</div>
          <div>ExecStartSecure=/usr/bin/security-ops \<br/>
            &nbsp;&nbsp;--web-servers=<span class="text-amber-600 dark:text-accent">"Nginx, Caddy, HAProxy"</span> \<br/>
            &nbsp;&nbsp;--ci-cd=<span class="text-amber-600 dark:text-accent">"GitHub Actions, GitLab CI"</span> \<br/>
            &nbsp;&nbsp;--hardening=<span class="text-amber-600 dark:text-accent">"SSH keys, UFW, fail2ban, SSL (Certbot)"</span> \<br/>
            &nbsp;&nbsp;--cloud-providers=<span class="text-amber-600 dark:text-accent">"AWS, GCP, DigitalOcean"</span></div>

          <div class="text-neutral-800 dark:text-neutral-200 font-bold mt-4">[Install]</div>
          <div>WantedBy=multi-user.target</div>
        </div>
      </div>

    </div>

  </div>
</section>
