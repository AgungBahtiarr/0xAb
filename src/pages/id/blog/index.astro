---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const allPosts = await getCollection('blog', ({ data, id }) => {
  return data.draft !== true && id.startsWith('id/');
});

// Sort by pubDate descending
const posts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Blog // 0xAb - Agung Bahtiar" description="Menulis tentang rekayasa backend, otomatisasi, administrasi sistem, dan pengembangan web modern.">
  <Header />
  
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 flex-grow w-full">
    <!-- Back Link -->
    <div class="mb-12">
      <a 
        href={translatePath('/')} 
        class="group inline-flex items-center gap-1.5 font-mono text-xs text-neutral-500 hover:text-accent transition-colors"
      >
        <svg class="w-3.5 h-3.5 transform transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"></path>
        </svg>
        {t('blog.backToPortfolio')}
      </a>
    </div>

    <!-- Title Header -->
    <div class="mb-16 border-b border-neutral-200/50 dark:border-neutral-800 pb-8">
      <span class="font-mono text-xs font-bold text-accent tracking-widest uppercase block mb-2">// 0XAB LOGS</span>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight text-neutral-950 dark:text-neutral-50">
        {t('blog.title')}
      </h1>
      <p class="text-neutral-500 dark:text-neutral-400 mt-2 text-sm sm:text-base max-w-xl">
        {t('blog.desc')}
      </p>
    </div>

    <!-- Blog Posts List -->
    <div class="space-y-12">
      {posts.length === 0 ? (
        <p class="text-neutral-500 font-mono text-sm">{t('blog.noPosts')}</p>
      ) : (
        posts.map((post) => (
          <article class="group flex flex-col md:flex-row md:items-baseline justify-between gap-4 border-b border-neutral-200/30 dark:border-neutral-800/30 pb-8">
            <div class="space-y-2 max-w-2xl">
              <!-- Date -->
              <div class="font-mono text-[11px] text-neutral-400 dark:text-neutral-500">
                {post.data.pubDate.toLocaleDateString(lang === 'id' ? 'id-ID' : 'en-US', { dateStyle: 'long' })}
              </div>
              
              <!-- Title -->
              <h2 class="text-xl sm:text-2xl font-bold text-neutral-950 dark:text-neutral-50 group-hover:text-accent transition-colors">
                <a href={translatePath(`/blog/${post.id.replace(/^(en|id)\//, '')}`)}>{post.data.title}</a>
              </h2>
              
              <!-- Description -->
              <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
                {post.data.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 pt-2 font-mono text-[10px] text-neutral-400">
                {post.data.tags.map((tag) => (
                  <span class="px-2 py-0.5 border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/60 rounded">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>

            <!-- Read Link / CTA -->
            <a 
              href={translatePath(`/blog/${post.id.replace(/^(en|id)\//, '')}`)} 
              class="font-mono text-xs text-neutral-900 dark:text-neutral-100 hover:text-accent dark:hover:text-accent font-semibold flex items-center gap-1 group-hover:translate-x-1 transition-all flex-shrink-0 md:pt-0 pt-2"
            >
              {t('blog.readLog')}
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
              </svg>
            </a>
          </article>
        ))
      )}
    </div>

  </main>
  
  <Footer />
</Layout>
