---
import "../styles/global.css";
import { getCollection } from 'astro:content';

interface Props {
  title?: string;
  description?: string;
}

const allProfiles = await getCollection('profile');
const profileEntry = allProfiles[0];
const profile = profileEntry?.data;

const { 
  title = profile ? `${profile.name} // ${profile.role} & ${profile.subRole}` : "0xAb // Agung Bahtiar - Software Engineer & System Administrator", 
  description = profile?.tagline || "Portfolio of Agung Bahtiar (0xAb), a Software Engineer and System Administrator."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <!-- Favicon -->
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        
        <!-- SEO Meta Tags -->
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="generator" content={Astro.generator} />
        <meta name="author" content="Agung Bahtiar" />
        
        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content="/logo/logo-dark.png" />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content="/logo/logo-dark.png" />

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Outfit:wght@100..900&display=swap" rel="stylesheet">

        <!-- Theme Initialization Script (Avoids Flash of Unstyled Content) -->
        <script is:inline>
            (function () {
                const getTheme = () => {
                    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                        return localStorage.getItem('theme');
                    }
                    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                };
                
                const theme = getTheme();
                if (theme === 'dark') {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            })();
        </script>
    </head>
    <body class="bg-neutral-50 text-neutral-900 dark:bg-neutral-950 dark:text-neutral-50 transition-colors duration-300 font-sans selection:bg-accent selection:text-neutral-950 min-h-screen flex flex-col">
        <slot />
    </body>
</html>

