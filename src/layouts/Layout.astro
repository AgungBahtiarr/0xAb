---
import "../styles/global.css";
import { getCollection } from 'astro:content';
import { SEO } from 'astro-seo';
import '@fontsource-variable/outfit';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/jetbrains-mono/wght-italic.css';

import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const allProfiles = await getCollection('profile');
let profileEntry = allProfiles.find(p => p.id === `${lang}/about`);
if (!profileEntry) {
  profileEntry = allProfiles.find(p => p.id === 'en/about') || allProfiles[0];
}
const profile = profileEntry?.data;

const { 
  title = profile ? `${profile.name} // ${profile.role} & ${profile.subRole}` : "0xAb // Agung Bahtiar - Software Engineer & System Administrator", 
  description = profile?.tagline || "Portfolio of Agung Bahtiar (0xAb), a Software Engineer and System Administrator."
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url);
const logoURL = new URL("/logo/logo-dark.png", Astro.url).toString();

// JSON-LD Structured Data to tell Google search engines exactly who you are
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": profile?.name || "Agung Bahtiar",
  "alternateName": "0xAb",
  "url": Astro.site?.toString() || "https://0xab.my.id",
  "image": new URL("/logo/logo-dark.png", Astro.site || Astro.url).toString(),
  "sameAs": [
    profile?.twitter,
    profile?.linkedin,
    profile?.github
  ].filter(Boolean),
  "jobTitle": profile ? `${profile.role} & ${profile.subRole}` : "Software Engineer & System Administrator",
  "description": description,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Banyuwangi",
    "addressRegion": "Jawa Timur",
    "addressCountry": "ID"
  },
  "alumniOf": {
    "@type": "EducationalOrganization",
    "name": "Politeknik Negeri Banyuwangi",
    "alternateName": "Poliwangi"
  }
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <SEO
            title={title}
            description={description}
            canonical={canonicalURL.toString()}
            openGraph={{
                basic: {
                    title: title,
                    type: "website",
                    image: logoURL,
                    url: Astro.url.toString(),
                }
            }}
            twitter={{
                card: "summary_large_image",
                title: title,
                description: description,
                image: logoURL,
            }}
            extend={{
                meta: [
                    { name: "generator", content: Astro.generator },
                    { name: "author", content: "Agung Bahtiar" },
                    { 
                        name: "keywords", 
                        content: "Agung Bahtiar, 0xAb, Agung Bahtiar Poliwangi, Agung Bahtiar Banyuwangi, Agung Bahtiar Laros, Politeknik Negeri Banyuwangi, Poliwangi, Banyuwangi, Agung Bahtiar Portfolio, Agung Bahtiar Software Engineer, Agung Bahtiar SysAdmin, Software Engineer Indonesia, System Administrator Indonesia, DevOps, Linux System Administrator, Web Developer" 
                    }
                ],
                link: [
                    { rel: "icon", type: "image/svg+xml", href: "/favicon.svg" },
                    { rel: "icon", href: "/favicon.ico" }
                ]
            }}
        />

        <!-- JSON-LD Structured Data for Search Engine Optimization -->
        <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />



        <!-- Theme Initialization Script (Avoids Flash of Unstyled Content) -->
        <script is:inline>
            (function () {
                const getTheme = () => {
                    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                        return localStorage.getItem('theme');
                    }
                    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                };
                
                const theme = getTheme();
                if (theme === 'dark') {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            })();
        </script>
    </head>
    <body class="bg-neutral-50 text-neutral-900 dark:bg-neutral-950 dark:text-neutral-50 transition-colors duration-300 font-sans selection:bg-accent selection:text-neutral-950 min-h-screen flex flex-col">
        <slot />
    </body>
</html>

